# API Server Configuration
PORT=3010

# API Key for authentication (optional - if set, all API requests require Bearer token auth)
# Generate a secure key with: openssl rand -hex 32
API_KEY=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database path (optional, defaults to ./payroll.db)
PAYROLL_DB_PATH=./payroll.db
