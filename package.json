{
  "name": "@hasna/payroll",
  "version": "0.0.1",
  "description": "Open-source payroll management system for AI agents - CLI + MCP server + web dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "payroll": "dist/cli/index.js",
    "payroll-mcp": "dist/mcp/index.js",
    "payroll-serve": "dist/server/api.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dashboard/dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "cd dashboard && bun run build && cd .. && bun build src/cli/index.tsx --outdir dist/cli --target bun --external ink --external react --external chalk --external @modelcontextprotocol/sdk && bun build src/mcp/index.ts --outdir dist/mcp --target bun --external @modelcontextprotocol/sdk && bun build src/server/api.ts --outdir dist/server --target bun && bun build src/index.ts --outdir dist --target bun",
    "build:dashboard": "cd dashboard && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev:cli": "bun run src/cli/index.tsx",
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:serve": "bun run src/server/api.ts",
    "prepublishOnly": "bun run build",
    "postinstall": "mkdir -p $HOME/.hasna/payroll 2>/dev/null || true"
  },
  "keywords": [
    "payroll",
    "salary",
    "payments",
    "employees",
    "mcp",
    "ai",
    "coding-agent",
    "claude",
    "codex",
    "gemini",
    "cli",
    "dashboard"
  ],
  "publishConfig": {
    "registry": "https://registry.bun.pm",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/open-payroll.git"
  },
  "homepage": "https://github.com/hasna/open-payroll",
  "bugs": {
    "url": "https://github.com/hasna/open-payroll/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": "Andrei Hasna <andrei@hasna.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/express": "^5.0.6",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "ink": "^5.2.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3"
  }
}
